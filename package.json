{
  "name": "selsa-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "audit:tokens": "node ./scripts/audit-no-storage-tokens.mjs",
    "clean:next": "node -e \"const fs=require('fs');const path=require('path');const rm=(p)=>{try{fs.rmSync(p,{recursive:true,force:true});}catch(e){}};rm(path.join(process.cwd(),'.next'));rm(path.join(process.cwd(),'node_modules','.cache'));console.log('✅ Cleaned .next and node_modules/.cache');\"",
    "dev:clean": "npm run clean:next && next dev",
    "dev": "next dev",
    "dev:turbopack": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:all": "npm run dev:stop && concurrently --kill-others-on-fail \"npm run backend\" \"npm run dev\"",
    "dev:all:ifneeded": "concurrently --kill-others-on-fail \"npm run backend:ifneeded\" \"npm run dev:ifneeded\"",
    "backend": "cd ../selsa-backend && ../.venv/bin/python manage.py runserver",
    "backend:ifneeded": "node -e \"const http=require('http');const req=http.request({hostname:'127.0.0.1',port:8000,method:'GET',path:'/'},()=>{console.log('Backend already running on :8000');process.exit(0)});req.on('error',()=>{process.exit(1)});req.end();\" || npm run backend",
    "dev:ifneeded": "node -e \"const http=require('http');const req=http.request({hostname:'127.0.0.1',port:3000,method:'GET',path:'/'},res=>{console.log('Frontend already running on :3000');process.exit(0)});req.on('error',()=>{process.exit(1)});req.end();\" || npm run dev",
    "dev:stop": "node -e \"const {execSync}=require('child_process');try{execSync('lsof -ti tcp:3000 | xargs kill -9', {stdio:'inherit'});}catch(e){} try{execSync('lsof -ti tcp:8000 | xargs kill -9', {stdio:'inherit'});}catch(e){}\"",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.5",
    "@fontsource-variable/ibm-plex-sans": "^5.2.5",
    "@fontsource-variable/playfair-display": "^5.2.5",
    "@fontsource-variable/roboto-flex": "^5.2.5",
    "@fontsource-variable/syne": "^5.2.5",
    "@fontsource-variable/work-sans": "^5.2.5",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "6.10.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@sentry/nextjs": "^10.40.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@tanstack/react-query": "^5.77.2",
    "@tanstack/react-query-devtools": "^5.77.2",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.511.0",
    "next": "^16.1.4",
    "next-auth": "^4.24.13",
    "paypal-rest-sdk": "^1.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.59.0",
    "react-hot-toast": "^2.5.2",
    "react-parallax": "^3.5.2",
    "react-scroll-parallax": "^3.4.5",
    "sonner": "^2.0.5",
    "stripe": "^20.3.0",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "babel-jest": "^30.2.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.3.2",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.0.0",
    "playwright": "^1.58.1",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prisma": "6.10.1",
    "react-i18next": "^16.5.4",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
